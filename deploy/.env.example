# Telegram bot token (from @BotFather)
BOT_TOKEN=123456:ABC-DEF...

# GitHub API token (for autochecker to read student repos)
# https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenRouter API key (for LLM-based quality checks)
# https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LLM model (OpenRouter format)
LLM_MODEL=google/gemini-2.5-flash-lite

# Comma-separated list of active labs shown to students
ACTIVE_LABS=lab-01

# Max check attempts per task per student
MAX_ATTEMPTS_PER_TASK=3

# Dashboard password (leave empty to disable auth)
DASHBOARD_PASSWORD=
